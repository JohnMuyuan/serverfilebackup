#!/usr/bin/env bash
set -Eeuo pipefail

SELF_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
APP_DIR="${SERVER_BACKUP_APP_DIR:-$(cd -- "$(dirname -- "$SELF_PATH")" && pwd)}"
CONFIG_DIR="${SERVER_BACKUP_CONFIG_DIR:-/etc/server-archive-backup}"
INSTALL_CONFIG="$CONFIG_DIR/install.conf"
BACKUP_CONFIG="$CONFIG_DIR/backup.conf"
BACKUP_SCRIPT="$APP_DIR/backup.sh"
SERVICE_NAME="server-archive-backup.service"
TIMER_NAME="server-archive-backup.timer"

say() { printf '%s\n' "$*"; }
die() { say "错误：$*" >&2; exit 1; }

prompt() {
  local message="$1" default="${2:-}" answer
  if [[ -n "$default" ]]; then
    printf '%s [%s]: ' "$message" "$default" > /dev/tty
  else
    printf '%s: ' "$message" > /dev/tty
  fi
  IFS= read -r answer < /dev/tty || true
  printf '%s' "${answer:-$default}"
}

confirm() {
  local message="$1" default="${2:-N}" answer suffix="y/N"
  [[ "$default" =~ ^[Yy]$ ]] && suffix="Y/n"
  printf '%s [%s]: ' "$message" "$suffix" > /dev/tty
  IFS= read -r answer < /dev/tty || true
  answer="${answer:-$default}"
  [[ "$answer" =~ ^[Yy]$ ]]
}

pause() {
  printf '\n按回车键继续...' > /dev/tty
  IFS= read -r _ < /dev/tty || true
}

require_root() {
  (( EUID == 0 )) || die "请使用 sudo backupctl 运行配置菜单"
}

load_install_config() {
  [[ -f "$INSTALL_CONFIG" ]] || die "尚未完成安装：$INSTALL_CONFIG 不存在"
  # shellcheck source=/dev/null
  source "$INSTALL_CONFIG"
  : "${RUN_USER:?install.conf 中缺少 RUN_USER}"
  [[ -f "$BACKUP_CONFIG" ]] || die "找不到 $BACKUP_CONFIG"
  [[ -x "$BACKUP_SCRIPT" ]] || die "找不到可执行备份脚本 $BACKUP_SCRIPT"
}

as_run_user() {
  if [[ "$(id -un)" == "$RUN_USER" ]]; then
    "$@"
  else
    runuser -u "$RUN_USER" -- "$@"
  fi
}

run_backup() {
  as_run_user env BACKUP_CONFIG="$BACKUP_CONFIG" "$BACKUP_SCRIPT" "$@"
}

write_scalar() {
  local name="$1" value="$2"
  printf '%s=' "$name"
  printf '%q' "$value"
  printf '\n'
}

write_array() {
  local name="$1"; shift
  local item
  printf '%s=(\n' "$name"
  for item in "$@"; do
    printf '  '
    printf '%q' "$item"
    printf '\n'
  done
  printf ')\n'
}

job_file_by_name() {
  local wanted="$1" file found=""
  shopt -s nullglob
  for file in "$CONFIG_DIR/jobs.d"/*.conf; do
    JOB_NAME=""
    # shellcheck source=/dev/null
    source "$file"
    if [[ "$JOB_NAME" == "$wanted" ]]; then
      found="$file"
      break
    fi
  done
  shopt -u nullglob
  printf '%s' "$found"
}

ensure_ssh_key() {
  local key="$1" key_dir
  [[ -f "$key" ]] && return 0
  if ! confirm "SSH 密钥不存在，是否现在为 $RUN_USER 创建？" Y; then
    return 1
  fi
  key_dir="$(dirname -- "$key")"
  as_run_user mkdir -p -- "$key_dir"
  as_run_user chmod 700 "$key_dir"
  as_run_user ssh-keygen -q -t ed25519 -N '' -f "$key"
  say "密钥已创建：$key"
}

ensure_remote_rsync() {
  local host="$1" user="$2" port="$3" key="$4" install_command
  local -a ssh_command=(ssh -p "$port" -i "$key" -o BatchMode=yes -o StrictHostKeyChecking=accept-new)

  if as_run_user "${ssh_command[@]}" "$user@$host" 'command -v rsync >/dev/null'; then
    say "远端 rsync 已安装。"
    return 0
  fi

  say "远端服务器尚未安装 rsync，断点续传需要它。"
  if ! confirm "是否现在自动在远端安装 rsync？" Y; then
    say "已跳过安装；任务已保存，但运行前必须先安装远端 rsync。"
    return 1
  fi

  install_command='set -Eeuo pipefail
run_root() {
  if [ "$(id -u)" -eq 0 ]; then "$@";
  elif command -v sudo >/dev/null; then sudo "$@";
  else echo "当前用户没有 root 或 sudo 权限，无法自动安装 rsync" >&2; exit 1; fi
}
if command -v apt-get >/dev/null; then
  run_root apt-get update
  run_root apt-get install -y rsync
elif command -v dnf >/dev/null; then
  run_root dnf install -y rsync
elif command -v yum >/dev/null; then
  run_root yum install -y rsync
else
  echo "不支持远端包管理器，请手动安装 rsync" >&2
  exit 1
fi'

  if ! as_run_user ssh -tt -p "$port" -i "$key" -o StrictHostKeyChecking=accept-new \
    "$user@$host" "$install_command" < /dev/tty > /dev/tty; then
    say "远端 rsync 自动安装失败，请检查上方错误信息。"
    return 1
  fi

  as_run_user "${ssh_command[@]}" "$user@$host" 'command -v rsync >/dev/null' \
    || { say "安装完成后仍未找到远端 rsync。"; return 1; }
  say "远端 rsync 安装完成。"
}

add_job() {
  local name host user port key retention compression transfer parallel path pattern pre post file existing remote_dependencies
  local user_home
  local -a paths=() excludes=()

  say ""
  say "添加备份任务"
  say "路径示例：/var/www/blog、/home/mc/backups、/var/vmail"
  while true; do
    name="$(prompt '任务名称（英文/数字/短横线）')"
    [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] && break
    say "任务名称格式不正确。"
  done
  existing="$(job_file_by_name "$name")"
  if [[ -n "$existing" ]] && ! confirm "任务已存在，是否覆盖？"; then return 0; fi

  host="$(prompt '服务器 IP 或域名')"
  [[ -n "$host" ]] || die "服务器地址不能为空"
  user="$(prompt 'SSH 用户名' 'backup')"
  port="$(prompt 'SSH 端口' '22')"
  [[ "$port" =~ ^[0-9]+$ ]] || die "SSH 端口格式错误"

  user_home="$(getent passwd "$RUN_USER" | cut -d: -f6)"
  key="$(prompt 'SSH 私钥路径' "$user_home/.ssh/server_backup_ed25519")"

  while true; do
    path="$(prompt '要备份的远端绝对路径（输入完毕直接回车）')"
    [[ -z "$path" ]] && break
    [[ "$path" == /* ]] || { say "必须是以 / 开头的绝对路径。"; continue; }
    paths+=("$path")
  done
  (( ${#paths[@]} > 0 )) || die "至少需要一个备份路径"

  while true; do
    pattern="$(prompt '排除规则（可选，例如 */cache/*；输入完毕回车）')"
    [[ -z "$pattern" ]] && break
    excludes+=("$pattern")
  done

  retention="$(prompt '最多保留多少份（0 表示不限）' '100')"
  [[ "$retention" =~ ^[0-9]+$ ]] || die "保留数量必须是非负整数"
  compression="$(prompt '压缩级别 1-9' '6')"
  [[ "$compression" =~ ^[1-9]$ ]] || die "压缩级别必须是 1-9"
  transfer="mirror"
  if ! confirm "是否启用断点续传和后续增量同步？" Y; then
    transfer="stream"
  fi
  parallel="1"
  if [[ "$transfer" == "mirror" ]]; then
    parallel="$(prompt '并行下载连接数 1-16（跨地区推荐 4）' '4')"
    [[ "$parallel" =~ ^([1-9]|1[0-6])$ ]] || die "并行连接数必须是 1-16"
  fi

  pre=""; post=""
  if confirm "是否配置数据库导出等高级前置/清理命令？"; then
    pre="$(prompt '备份前远端命令（可留空）')"
    post="$(prompt '备份后远端命令（可留空）')"
  fi

  file="$CONFIG_DIR/jobs.d/$name.conf"
  umask 027
  {
    write_scalar JOB_NAME "$name"
    write_scalar REMOTE_HOST "$host"
    write_scalar REMOTE_USER "$user"
    write_scalar REMOTE_PORT "$port"
    write_scalar SSH_KEY "$key"
    write_array SOURCE_PATHS "${paths[@]}"
    write_array EXCLUDE_PATTERNS "${excludes[@]}"
    write_scalar RETENTION_COUNT "$retention"
    write_scalar COMPRESSION_LEVEL "$compression"
    write_scalar TRANSFER_MODE "$transfer"
    write_scalar PARALLEL_TRANSFERS "$parallel"
    write_scalar REMOTE_PRE_COMMAND "$pre"
    write_scalar REMOTE_POST_COMMAND "$post"
  } > "$file.tmp"
  mv -f -- "$file.tmp" "$file"
  chown root:"$RUN_USER" "$file"
  chmod 640 "$file"
  say "任务已保存：$name"

  if ensure_ssh_key "$key" && confirm "是否把公钥复制到远端服务器？（需要输入一次远端密码）" Y; then
    as_run_user ssh-copy-id -p "$port" -i "$key.pub" "$user@$host" < /dev/tty > /dev/tty
  fi
  if [[ "$transfer" == "mirror" ]] && ! ensure_remote_rsync "$host" "$user" "$port" "$key"; then
    return 0
  fi
  if confirm "是否立即测试 SSH 和执行第一次备份？" Y; then
    remote_dependencies="bash tar gzip"
    [[ "$transfer" == "mirror" ]] && remote_dependencies="bash rsync"
    as_run_user ssh -p "$port" -i "$key" -o BatchMode=yes -o StrictHostKeyChecking=accept-new \
      "$user@$host" "for cmd in $remote_dependencies; do command -v \"\$cmd\" >/dev/null || { echo \"远端缺少依赖: \$cmd\"; exit 1; }; done; echo SSH连接及远端依赖正常" < /dev/tty > /dev/tty
    run_backup --job "$name"
  fi
}

list_jobs() {
  say ""
  run_backup --list || true
}

run_one() {
  local name
  list_jobs
  name="$(prompt '输入要运行的任务名称')"
  [[ -n "$name" ]] && run_backup --job "$name"
}

configure_timer() {
  local scope job_name job_file frequency time weekday month_day on_calendar description
  local target_timer target_service timer_file unit_line=""
  local -a weekdays=(Mon Tue Wed Thu Fri Sat Sun)
  local -a weekday_labels=(一 二 三 四 五 六 日)

  say ""
  say "1. 只设置一个备份任务（推荐，可让不同任务使用不同周期）"
  say "2. 设置全部任务的统一周期"
  scope="$(prompt '请选择定时范围' '1')"
  case "$scope" in
    1)
      list_jobs
      job_name="$(prompt '输入要设置周期的任务名称')"
      job_file="$(job_file_by_name "$job_name")"
      [[ -n "$job_file" ]] || { say "没有找到任务：$job_name"; return 0; }
      target_timer="server-archive-backup@${job_name}.timer"
      target_service="server-archive-backup@${job_name}.service"
      timer_file="/etc/systemd/system/$target_timer"
      unit_line="Unit=$target_service"
      if systemctl is-enabled --quiet "$TIMER_NAME" 2>/dev/null; then
        if confirm "全局定时器会造成重复备份，是否现在禁用它？" Y; then
          systemctl disable --now "$TIMER_NAME"
        else
          say "已取消设置，避免任务被重复执行。"
          return 0
        fi
      fi
      ;;
    2)
      target_timer="$TIMER_NAME"
      target_service="$SERVICE_NAME"
      timer_file="/etc/systemd/system/$target_timer"
      unit_line="Unit=$target_service"
      say "注意：如已配置单任务定时器，全局周期可能造成重复备份。"
      confirm "确定要为全部任务设置统一周期？" || return 0
      ;;
    *)
      say "无效的范围选项"
      return 0
      ;;
  esac

  say ""
  say "1. 每天一次"
  say "2. 每周一次"
  say "3. 每月一次"
  say "4. 自定义 systemd OnCalendar 表达式"
  frequency="$(prompt '请选择备份周期' '1')"

  if [[ "$frequency" =~ ^[123]$ ]]; then
    time="$(prompt '运行时间（HH:MM，24小时制）' '03:15')"
    [[ "$time" =~ ^([01][0-9]|2[0-3]):[0-5][0-9]$ ]] || { say "时间格式应为 HH:MM"; return 0; }
  fi

  case "$frequency" in
    1)
      on_calendar="*-*-* ${time}:00"
      description="每天约 $time"
      ;;
    2)
      weekday="$(prompt '星期几（1=周一，2=周二……7=周日）' '7')"
      [[ "$weekday" =~ ^[1-7]$ ]] || { say "星期必须是 1-7"; return 0; }
      on_calendar="${weekdays[$((weekday - 1))]} *-*-* ${time}:00"
      description="每周${weekday_labels[$((weekday - 1))]}约 $time"
      ;;
    3)
      month_day="$(prompt '每月几号（建议 1-28）' '1')"
      [[ "$month_day" =~ ^([1-9]|1[0-9]|2[0-8])$ ]] || { say "日期必须是 1-28"; return 0; }
      printf -v month_day '%02d' "$((10#$month_day))"
      on_calendar="*-*-${month_day} ${time}:00"
      description="每月 ${month_day} 日约 $time"
      ;;
    4)
      on_calendar="$(prompt '请输入 OnCalendar 表达式')"
      [[ -n "$on_calendar" ]] || { say "表达式不能为空"; return 0; }
      description="$on_calendar"
      ;;
    *)
      say "无效的周期选项"
      return 0
      ;;
  esac

  if command -v systemd-analyze >/dev/null 2>&1 \
    && ! systemd-analyze calendar "$on_calendar" >/dev/null 2>&1; then
    say "OnCalendar 表达式无效：$on_calendar"
    return 0
  fi

  cat > "$timer_file" <<EOF
[Unit]
Description=Run server archive backup on schedule

[Timer]
OnCalendar=$on_calendar
Persistent=true
RandomizedDelaySec=5m
$unit_line

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload
  systemctl enable "$target_timer"
  systemctl restart "$target_timer"
  say "定时备份已启用：$description 运行（最多随机延迟 5 分钟）"
  systemctl list-timers "$target_timer" --no-pager || true
}

remove_job() {
  local name file
  list_jobs
  name="$(prompt '输入要删除的任务名称')"
  file="$(job_file_by_name "$name")"
  [[ -n "$file" ]] || die "没有找到任务：$name"
  if confirm "仅删除任务配置，不删除已有归档。确定吗？"; then
    systemctl disable --now "server-archive-backup@${name}.timer" >/dev/null 2>&1 || true
    rm -f -- "/etc/systemd/system/server-archive-backup@${name}.timer"
    rm -f -- "$file"
    systemctl daemon-reload
    say "任务已删除；历史归档仍然保留。"
  fi
}

show_status() {
  systemctl list-timers 'server-archive-backup*.timer' --all --no-pager || true
  say ""
  journalctl -u "$SERVICE_NAME" -u 'server-archive-backup@*.service' -n 50 --no-pager || true
}

menu() {
  require_root
  load_install_config
  while true; do
    clear 2>/dev/null || true
    say "========================================"
    say "        服务器自动备份管理器"
    say "========================================"
    say "1. 添加或修改备份任务"
    say "2. 查看已有任务"
    say "3. 立即运行一个任务"
    say "4. 立即运行全部任务"
    say "5. 为任务设置独立备份周期（日/周/月/自定义）"
    say "6. 查看定时器状态和最近日志"
    say "7. 删除任务（保留归档）"
    say "0. 退出"
    say ""
    case "$(prompt '请选择')" in
      1) add_job; pause ;;
      2) list_jobs; pause ;;
      3) run_one; pause ;;
      4) run_backup; pause ;;
      5) configure_timer; pause ;;
      6) show_status; pause ;;
      7) remove_job; pause ;;
      0) return 0 ;;
      *) say "无效选项"; sleep 1 ;;
    esac
  done
}

case "${1:-menu}" in
  menu) menu ;;
  add) require_root; load_install_config; add_job ;;
  list) require_root; load_install_config; list_jobs ;;
  run) require_root; load_install_config; shift; run_backup "$@" ;;
  schedule) require_root; load_install_config; configure_timer ;;
  status) require_root; load_install_config; show_status ;;
  *) die "用法：backupctl [menu|add|list|run|schedule|status]" ;;
esac
